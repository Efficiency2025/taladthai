# ============================================================
# Talad Thai Check-in — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Vite automatically loads:
#   .env                — always
#   .env.local          — always, git-ignored
#   .env.[mode]         — only in specified mode (development/production)
#   .env.[mode].local   — only in specified mode, git-ignored
#
# Only variables prefixed with VITE_ are exposed to client code
# via import.meta.env.VITE_*
# ============================================================

# ----- Firebase Configuration -----
# Get these from: Firebase Console > Project Settings > General > Your apps
# https://console.firebase.google.com/project/_/settings/general
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ----- App Settings -----
# [OPTIONAL] Auto-refresh interval in ms (default: 120000 = 2 min)
VITE_AUTO_REFRESH_INTERVAL=120000

# [OPTIONAL] Number of retry attempts for write operations (default: 3)
VITE_RETRY_ATTEMPTS=3

# [OPTIONAL] Base delay between retries in ms (default: 1000)
VITE_RETRY_BASE_DELAY=1000

# ----- Mock Data Mode -----
# Set to "true" to use local sample data without hitting Firestore.
# Great for offline dev, UI work, and onboarding new developers.
VITE_USE_MOCK_DATA=false
